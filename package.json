{
  "name": "painel-external-app",
  "version": "0.1.0",
  "description": "Empacota o Painel Web em um aplicativo desktop Electron e fornece um site de download.",
  "author": {
    "name": "Painel Team",
    "email": "team@example.com",
    "url": "https://example.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.painel.external",
    "productName": "Painel Cheat",
    "files": [
      "main.js",
      "preload.js",
      "cheat-panel/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "mac": {
      "target": ["dmg", "zip"]
    }
  },
  "dependencies": {
  },
  "devDependencies": {
    "electron": "^26.3.1",
    "electron-builder": "^24.6.2"
  }
}
